# Used only when the OpenAI-compatible endpoint requires a key.
# vLLM usually accepts any non-empty string, so the runner defaults to EMPTY.
OPENAI_API_KEY=EMPTY

# Optional, only if --use_wandb is passed.
WANDB_API_KEY=

# vLLM deployment defaults used by deploy_vllm_model.sh.
MODEL_NAME=openai/gpt-oss-20b
GPU_ID=0
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
MAX_MODEL_LEN=38000
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.90
DTYPE=auto
